@page
@model RazorPagesLab.Pages.Cities.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<form>
    <p>
        <select asp-for="CityCountry" asp-items="Model.Country">
            <option value="">All</option>
        </select>
        <label>Title: <input type="text" asp-for="SearchString" /></label>
        <input type="submit" value="Filter" />
    </p>
</form>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.City[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.City[0].DateVisited)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.City[0].StateRegion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.City[0].Country)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.City[0].Population)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.City[0].DaysSpent)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.City) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DateVisited)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StateRegion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Country)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Population)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DaysSpent)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
